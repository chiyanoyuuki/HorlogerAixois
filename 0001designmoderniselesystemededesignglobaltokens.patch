+
+/* ===================================================================
+   Raffinements globaux — homogénéité & modernité
+   =================================================================== */
+
+/* Titres de section : espacement typographique + filet d'accent centré */
+.title {
+  letter-spacing: 0.05em;
+  line-height: 1.2;
+}
+.bloctexte .title::after,
+.about .bloc .title::after,
+.watches > .title::after,
+.horology .title::after {
+  content: '';
+  display: block;
+  width: 54px;
+  height: 2px;
+  margin: 1.4vh auto 0;
+  background: var(--accent);
+  opacity: 0.8;
+}
+.smalltitle {
+  letter-spacing: 0.08em;
+  color: var(--text-soft);
+}
+
+/* Sections alternées plus douces + coins arrondis sur grand écran */
+.graybloc {
+  background-color: var(--surface);
+  border-top: 1px solid var(--border);
+  border-bottom: 1px solid var(--border);
+}
+
+/* Transition d'entrée de page plus fluide */
+.page {
+  opacity: 0;
+  transform: translateY(10px);
+  transition:
+    opacity 0.5s var(--ease),
+    transform 0.5s var(--ease);
+}
+.page.showContent {
+  opacity: 1;
+  transform: translateY(0);
+}
+
+/* Champs de formulaire homogènes */
+input[type='text'],
+input[type='number'],
+input[type='date'],
+input[type='email'],
+input[type='password'],
+textarea {
+  background: var(--surface-2);
+  border: 1px solid var(--border);
+  border-radius: var(--radius-sm);
+  padding: 9px 12px;
+  transition:
+    border-color 0.25s var(--ease),
+    box-shadow 0.25s var(--ease);
+}
+input[type='text']:focus,
+input[type='number']:focus,
+input[type='email']:focus,
+input[type='password']:focus,
+textarea:focus {
+  border-color: var(--accent);
+  box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 22%, transparent);
+  outline: none;
+}
+
+/* Images : rendu plus doux par défaut dans les cartes/carousels */
+img {
+  -webkit-user-drag: none;
+}
+
+/* Réduction des animations si demandé par l'utilisateur */
+@media (prefers-reduced-motion: reduce) {
+  *,
+  .page {
+    transition-duration: 0.01ms !important;
+    animation-duration: 0.01ms !important;
+    scroll-behavior: auto !important;
+  }
 }
