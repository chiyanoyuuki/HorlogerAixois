index 0000000..fb5842c
--- /dev/null
+++ b/backend/auth.php
@@ -0,0 +1,40 @@
+<?php
+/**
+ * Vérification du jeton admin — à inclure EN TÊTE des endpoints d'écriture
+ * (sethorlogeraixois, et montreshorloger.php pour action=add/update/delete)
+ * afin de protéger les modifications.
+ *
+ * Usage :
+ *   require __DIR__ . '/auth.php';
+ *   ha_require_auth('LA_MEME_CHAINE_SECRETE_QUE_login.php');
+ *
+ * Le front envoie le jeton dans l'en-tête HTTP :  Authorization: Bearer <token>
+ * (ou dans un champ POST `token`).
+ */
+
+function ha_require_auth(string $secret): void {
+    // Récupère le jeton depuis l'en-tête Authorization ou un champ POST.
+    $header = $_SERVER['HTTP_AUTHORIZATION'] ?? '';
+    if (stripos($header, 'Bearer ') === 0) {
+        $token = trim(substr($header, 7));
+    } else {
+        $token = $_POST['token'] ?? '';
+    }
+
+    $fail = function (string $reason) {
+        http_response_code(401);
+        echo json_encode(['error' => 'unauthorized', 'reason' => $reason]);
+        exit;
+    };
+
+    $parts = explode('.', $token);
+    if (count($parts) !== 2) $fail('no_token');
+
+    [$payload, $sig] = $parts;
+    $expected = hash_hmac('sha256', $payload, $secret);
+    if (!hash_equals($expected, $sig)) $fail('bad_signature');
+
+    $json = base64_decode(strtr($payload, '-_', '+/'));
+    $data = json_decode($json, true);
+    if (!is_array($data) || ($data['exp'] ?? 0) < time()) $fail('expired');
+}
