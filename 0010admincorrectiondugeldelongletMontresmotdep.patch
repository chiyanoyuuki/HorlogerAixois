new file mode 100644
index 0000000..0623943
--- /dev/null
+++ b/backend/login.php
@@ -0,0 +1,51 @@
+<?php
+/**
+ * Connexion admin sécurisée — HorlogerAixois
+ *
+ * Vérifie le mot de passe (haché avec password_hash) et renvoie un jeton
+ * signé (HMAC-SHA256) à durée de vie limitée. Le front stocke ce jeton et
+ * l'envoie sur les endpoints d'écriture, qui le vérifient via auth.php.
+ *
+ * ── Mise en place ────────────────────────────────────────────────────────
+ * 1) Générer le hash du mot de passe (UNE fois, en local ou via SSH) :
+ *      php -r "echo password_hash('VOTRE_MOT_DE_PASSE', PASSWORD_DEFAULT), PHP_EOL;"
+ *    Coller le résultat dans $PASSWORD_HASH ci-dessous.
+ * 2) Mettre une longue chaîne aléatoire privée dans $SECRET (identique à
+ *    celle utilisée dans auth.php).
+ * 3) Déposer login.php et auth.php à côté des autres scripts PHP.
+ */
+
+header('Access-Control-Allow-Origin: *');
+header('Access-Control-Allow-Methods: POST, OPTIONS');
+header('Access-Control-Allow-Headers: Content-Type, Authorization');
+header('Content-Type: application/json; charset=utf-8');
+
+if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
+    http_response_code(200);
+    exit;
+}
+
+// ===================== À PERSONNALISER =====================
+$PASSWORD_HASH = '$2y$10$REMPLACEZ_CECI_PAR_LE_HASH_GENERE';
+$SECRET        = 'REMPLACEZ_PAR_UNE_LONGUE_CHAINE_ALEATOIRE_PRIVEE';
+$TOKEN_TTL     = 60 * 60 * 8; // durée de validité du jeton : 8 heures
+// ==========================================================
+
+$input = json_decode(file_get_contents('php://input'), true);
+if (!is_array($input)) $input = [];
+$password = $input['password'] ?? ($_POST['password'] ?? '');
+
+if (!is_string($password) || !password_verify($password, $PASSWORD_HASH)) {
+    usleep(300000); // léger délai anti-force-brute
+    http_response_code(401);
+    echo json_encode(['ok' => false, 'error' => 'invalid_credentials']);
+    exit;
+}
+
+// Jeton = base64(payload) + "." + HMAC(payload)
+$exp     = time() + $TOKEN_TTL;
+$payload = rtrim(strtr(base64_encode(json_encode(['exp' => $exp])), '+/', '-_'), '=');
+$sig     = hash_hmac('sha256', $payload, $SECRET);
+$token   = $payload . '.' . $sig;
+
+echo json_encode(['ok' => true, 'token' => $token, 'exp' => $exp]);
